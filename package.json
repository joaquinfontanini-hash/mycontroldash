{
  "name": "workspace",
  "version": "1.0.0",
  "description": "mycontroldash — panel ejecutivo para estudio contable argentino",
  "license": "MIT",
  "private": true,

  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },

  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Usá pnpm en lugar de npm/yarn\" >&2; exit 1 ;; esac'",

    "build":           "pnpm run typecheck && pnpm -r --if-present run build",
    "build:backend":   "pnpm --filter @workspace/api-server run build",
    "build:frontend":  "pnpm --filter @workspace/dashboard run build",
    "build:db":        "pnpm --filter @workspace/db run build",

    "dev":             "pnpm -r --parallel --if-present run dev",
    "dev:backend":     "pnpm --filter @workspace/api-server run dev",
    "dev:frontend":    "pnpm --filter @workspace/dashboard run dev",

    "start":           "pnpm --filter @workspace/api-server run start",

    "typecheck":       "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "typecheck:libs":  "tsc --build",

    "db:push":         "pnpm --filter @workspace/db run push",
    "db:generate":     "pnpm --filter @workspace/db run generate",
    "db:migrate":      "pnpm --filter @workspace/db run migrate",

    "lint":            "pnpm -r --if-present run lint",
    "format":          "prettier --write \"**/*.{ts,tsx,js,json,yaml,md}\" --ignore-path .gitignore",
    "format:check":    "prettier --check \"**/*.{ts,tsx,js,json,yaml,md}\" --ignore-path .gitignore",

    "clean":           "pnpm -r --if-present run clean && rm -rf node_modules"
  },

  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier":   "^3.8.1"
  }
}

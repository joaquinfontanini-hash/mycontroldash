# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copiá este archivo a .env y completá los valores reales
# NUNCA commitees .env con valores reales al repositorio
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (Supabase PostgreSQL) ──────────────────────────────────────
# Obtené la connection string en: Supabase → Project → Settings → Database
#
# ⚠ IMPORTANTE: Para Railway (servidor long-running) usá la "Direct connection"
#   (puerto 5432), NO el Transaction pooler (6543) que es para serverless.
#   Direct:      postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
#   Pooler:      postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Puerto del servidor ───────────────────────────────────────────────────────
# ⚠ Railway inyecta PORT automáticamente en producción — no fijar en 3000.
#   El backend debe leer: const port = process.env.PORT ?? 3000
#   Dejá esta variable sin setear en Railway. Solo usala en desarrollo local.
PORT=3000

# ── Autenticación (Clerk) ─────────────────────────────────────────────────────
# Obtené estas keys en: https://dashboard.clerk.com → tu app → API Keys
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_FAPI=https://clerk.[tu-dominio].accounts.dev
CLERK_PROXY_PATH=/__clerk

# ── Seguridad de sesión ───────────────────────────────────────────────────────
# String aleatorio — mínimo 64 caracteres. Generá uno con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=cambia-esto-por-un-string-aleatorio-de-64-caracteres

# ── Encriptación de credenciales de email ─────────────────────────────────────
# Distinto a SESSION_SECRET — generá uno independiente con el mismo comando
EMAIL_ENCRYPTION_KEY=cambia-esto-por-otro-string-aleatorio-de-64-caracteres

# ── SMTP (alertas y notificaciones por email) ─────────────────────────────────
# Para Gmail: necesitás una "App Password" (no tu contraseña normal)
#   Configuración: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=tu-email@gmail.com

# ── API Keys externas ─────────────────────────────────────────────────────────
# SerpAPI para búsqueda de noticias: https://serpapi.com
# ⚠ Sin esta key el módulo de noticias falla. El backend valida su presencia al iniciar.
SERPAPI_KEY=tu_serpapi_key_aqui

# ── URLs de producción ────────────────────────────────────────────────────────
# URL pública del frontend en Vercel (sin slash al final)
APP_URL=https://tu-app.vercel.app

# Orígenes permitidos por CORS (coma-separados, sin espacios, sin slash al final)
# Incluí la URL del frontend en Vercel y cualquier dominio custom
ALLOWED_ORIGINS=https://tu-app.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# Variables del FRONTEND (Vite) — deben empezar con VITE_
# Configurar en: Vercel → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# URL del backend en Railway (sin slash al final)
VITE_API_URL=https://tu-backend.up.railway.app

# Clerk publishable key (pública, va en el frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL del proxy de Clerk — debe coincidir con CLERK_PROXY_PATH en el backend
VITE_CLERK_PROXY_URL=https://tu-backend.up.railway.app/__clerk

# ─────────────────────────────────────────────────────────────────────────────
# Solo para desarrollo local — NO setear en Vercel/Railway producción
# ─────────────────────────────────────────────────────────────────────────────

# Autenticación local (sin cuenta Clerk) — descomentá para usarla
# ⚠ NUNCA setear VITE_LOCAL_AUTH_MODE=true en el proyecto Vercel de producción
# VITE_LOCAL_AUTH_MODE=true
# VITE_LOCAL_EMAIL=admin@local.dev
# VITE_LOCAL_NAME=Admin Local
# VITE_LOCAL_PASSWORD=admin123

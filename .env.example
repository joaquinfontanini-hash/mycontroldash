# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copia este archivo a .env y completá los valores reales
# Nunca commitees .env con valores reales al repositorio
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (Supabase PostgreSQL) ──────────────────────────────────────
# Obtené la connection string en: Supabase → Project → Settings → Database
# Usá la "Transaction pooler" URL (puerto 6543) para serverless/Vercel
# Usá la "Direct connection" URL (puerto 5432) para servidores long-running
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Autenticación (Clerk) ────────────────────────────────────────────────────
# Obtené estas keys en: https://dashboard.clerk.com → tu app → API Keys
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_FAPI=https://clerk.[tu-dominio].accounts.dev
CLERK_PROXY_PATH=/__clerk

# ── Seguridad de sesión ──────────────────────────────────────────────────────
# String aleatorio largo (mínimo 32 caracteres). Generá uno con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia-esto-por-un-string-aleatorio-de-64-caracteres

# ── Encriptación de credenciales de email ───────────────────────────────────
# String aleatorio para encriptar las credenciales SMTP guardadas en DB
# Generá uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_ENCRYPTION_KEY=cambia-esto-por-otro-string-aleatorio-de-64-caracteres

# ── SMTP (para envío de emails: alertas, notificaciones) ────────────────────
# Ejemplo con Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Para Gmail necesitás una "App Password" (no tu contraseña normal)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=tu-email@gmail.com

# ── API Keys externas ────────────────────────────────────────────────────────
# SerpAPI para búsqueda de noticias: https://serpapi.com
SERPAPI_KEY=tu_serpapi_key_aqui

# ── URLs de producción ───────────────────────────────────────────────────────
# URL pública del frontend (para links en emails de recuperación de contraseña)
APP_URL=https://tu-app.vercel.app

# Orígenes permitidos por CORS (separados por coma, sin espacios al final)
# Incluí la URL del frontend en Vercel y cualquier dominio custom
ALLOWED_ORIGINS=https://tu-app.vercel.app

# ── Puerto del servidor backend ──────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# Variables del FRONTEND (Vite) — deben empezar con VITE_
# Configurar en Vercel → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# URL del backend API (sin slash al final)
# Si el backend está en Railway: https://tu-api.up.railway.app
# Si el backend está en Render: https://tu-api.onrender.com
VITE_API_URL=https://tu-backend.up.railway.app

# Clerk publishable key (la pública, va en el frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL del proxy de Clerk (debe coincidir con CLERK_PROXY_PATH en el backend)
VITE_CLERK_PROXY_URL=https://tu-backend.up.railway.app/__clerk

# ── Solo para desarrollo local sin Clerk ─────────────────────────────────────
# Descomentá estas para usar autenticación local (sin necesidad de cuenta Clerk)
# VITE_LOCAL_AUTH_MODE=true
# VITE_LOCAL_EMAIL=admin@local.dev
# VITE_LOCAL_NAME=Admin Local
# VITE_LOCAL_PASSWORD=admin123
